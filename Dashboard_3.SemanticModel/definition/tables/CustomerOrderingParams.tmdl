table CustomerOrderingParams
	lineageTag: 93aed575-ef81-4387-9592-e54a409690cb

	column MaxPayDate = ```
			
			VAR Client = 'CustomerOrderingParams'[CustomerKey]
			
			VAR RESULT = 
			MAXX(
			        FILTER(
			                'Sales data', 
			                'Sales data'[CustomerKey] = Client
			        ),
			        'Sales data'[OrderDate]
			)
			RETURN RESULT
			```
		formatString: General Date
		lineageTag: 6957e306-e8c9-4f77-8c3a-b9bc4f4f4176
		summarizeBy: none

		variation Variation
			isDefault
			relationship: c462c886-e3d0-4a2c-bc42-dacf3463e6d5
			defaultHierarchy: LocalDateTable_165bb4d9-f3b0-4362-a4ea-0c2d3a5befa1.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column PaymentsCount = ```
			
			VAR Client = 'CustomerOrderingParams'[CustomerKey]
			
			VAR RESULT = 
			COUNTAX(
			        FILTER(
			                'Sales data', 
			                'Sales data'[CustomerKey] = Client
			        ),
			        'Sales data'[CustomerKey]
			)
			RETURN RESULT
			```
		formatString: 0
		lineageTag: f2aeda87-053c-4553-915f-3e4235173071
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Amount = ```
			
			VAR Client = 'CustomerOrderingParams'[CustomerKey]
			
			VAR RESULT = 
			SUMX(
			        FILTER(
			                'Sales data', 
			                'Sales data'[CustomerKey] = Client
			        ),
			        'Sales data'[OrderQuantity]*RELATED('Product'[ProductPrice])
			)
			RETURN RESULT
			```
		lineageTag: 594f1920-9f8a-4064-b211-6862121e6c1b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column DaysPassed = DATEDIFF('CustomerOrderingParams'[MaxPayDate], MAX('Sales data'[OrderDate]),DAY)
		formatString: 0
		lineageTag: a73b371a-9751-44b4-85f8-f2ec13a01688
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation __PBI_SemanticLinks = [{"LinkTarget":{"TableName":"CustomerOrderingParams","TableItemName":"DaysPassed (bins)","ObjectType":4},"LinkType":"UsedInGroup"}]

	column 'DaysPassed (bins)' =
			IF(
				ISBLANK('CustomerOrderingParams'[DaysPassed]),
				BLANK(),
				INT('CustomerOrderingParams'[DaysPassed] / 20) * 20
			)
		formatString: 0
		lineageTag: 84417f57-e9c7-4048-93ef-70fa49e689d1
		summarizeBy: none

		extendedProperty GroupingMetadata =
				{
				  "version": 0,
				  "groupedColumns": [
				    {
				      "Column": {
				        "Expression": {
				          "SourceRef": {
				            "Entity": "CustomerOrderingParams"
				          }
				        },
				        "Property": "DaysPassed"
				      }
				    }
				  ],
				  "binningMetadata": {
				    "binSize": {
				      "value": 20.0,
				      "unit": 0
				    }
				  }
				}

		annotation GroupingDesignState = {"Version":0,"Sources":[{"Name":"c","Entity":"CustomerOrderingParams"}],"GroupedColumns":[{"Column":{"Expression":{"SourceRef":{"Source":"c"}},"Property":"DaysPassed"}}],"BinItem":{"Expression":{"Floor":{"Expression":{"Column":{"Expression":{"SourceRef":{"Source":"c"}},"Property":"DaysPassed"}},"Size":20.0}}}}

		annotation SummarizationSetBy = Automatic

	column R = ```
			
			VAR Recency_Good = PERCENTILE.INC('CustomerOrderingParams'[DaysPassed], 0.25)
			
			VAR Recency_Bad = PERCENTILE.INC('CustomerOrderingParams'[DaysPassed], 0.5)
			
			VAR result = SWITCH(    TRUE(),
			                        'CustomerOrderingParams'[DaysPassed] <= Recency_Good, 1, 
			                        'CustomerOrderingParams'[DaysPassed] <= Recency_Bad, 2,
			                        3
			                    )
			
			RETURN result
			```
		formatString: 0
		lineageTag: de716c30-96be-43f2-8c7c-860b3cc785e5
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column F = ```
			
			VAR Frequency_Good = PERCENTILE.INC(CustomerOrderingParams[PaymentsCount], 0.75)
			
			VAR Frequency_Bad = PERCENTILE.INC(CustomerOrderingParams[PaymentsCount], 0.5)
			
			VAR result = SWITCH(    TRUE(),
			                        'CustomerOrderingParams'[PaymentsCount] >= Frequency_Good, 1, 
			                        'CustomerOrderingParams'[PaymentsCount] >= Frequency_Bad, 2,
			                        3
			                    )
			
			RETURN result
			```
		formatString: 0
		lineageTag: 21fccbd3-94bd-4d19-91be-babcfa149f49
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column M = ```
			
			VAR Monetary_Good = PERCENTILE.INC(CustomerOrderingParams[Amount], 0.75)
			
			VAR Monetary_Bad = PERCENTILE.INC(CustomerOrderingParams[Amount], 0.5)
			
			VAR result = SWITCH(    TRUE(),
			                        'CustomerOrderingParams'[Amount] >= Monetary_Good, 1, 
			                        'CustomerOrderingParams'[Amount] >= Monetary_Bad, 2,
			                        3
			                    )
			
			RETURN result
			```
		formatString: 0
		lineageTag: a91acb76-1b85-456c-a03e-417a17dc4ff5
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column RFM = 100*'CustomerOrderingParams'[R] + 10*'CustomerOrderingParams'[F] + 'CustomerOrderingParams'[M]
		formatString: 0
		lineageTag: 5d54e629-6188-488d-80ea-e35f5a3b5ba4
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column CustomerKey
		formatString: 0
		lineageTag: 9f4267ce-0e0b-4d4f-8113-fead09df09e9
		summarizeBy: none
		isNameInferred
		sourceColumn: [CustomerKey]

		annotation SummarizationSetBy = Automatic

	column 'Customer Full Name' =
			
			RELATED('Customers'[Prefix]) & " " & RELATED(Customers[FirstName]) & " " & RELATED('Customers'[LastName])
		lineageTag: 593dee16-4e28-45f6-aa01-279e4b3a8946
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Amount cats' = ```
			
			SWITCH(    
			    TRUE(),
			    'CustomerOrderingParams'[Amount] <= 5, "0-5", 
			    'CustomerOrderingParams'[Amount] <= 10, "5-10",
			    'CustomerOrderingParams'[Amount] <= 50, "10-50", 
			    'CustomerOrderingParams'[Amount] <= 100, "50-100", 
			    'CustomerOrderingParams'[Amount] <= 500, "100-500",
			    'CustomerOrderingParams'[Amount] <= 1000, "500-1000", 
			    'CustomerOrderingParams'[Amount] <= 5000, "1000-5000", 
			    'CustomerOrderingParams'[Amount] <= 10000, "5000-10000", 
			                        "10000+"
			)
			```
		lineageTag: 1f243da3-7ce0-4ef3-9dfc-424861ae0f2b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition CustomerOrderingParams = calculated
		mode: import
		source = ```
				
				VAR FiltTable = 
				                FILTER('Sales data',
				                        AND(
				                            'Sales data'[OrderDate] >= MIN('Calendar'[Date]),
				                            'Sales data'[OrderDate] <= MAX('Calendar'[Date])
				                        )
				                )
				VAR Col = SELECTCOLUMNS(FiltTable, "CustomerKey", [CustomerKey])
				RETURN DISTINCT(Col)
				                
				```

	annotation PBI_Id = fb7bf2e2a0834c618fce711164ffcc07

